#!/bin/bash
# SPDX-License-Identifier: MIT
#
# build — Build and install ovgl v0.2.0
#
# Usage:
#   ./build              Build and install
#   ./build -c           Clean reinstall (remove everything, rebuild)
#   ./build --clean      Same as -c
#

set -eu

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PREFIX="${PREFIX:-/data/data/com.termux/files/usr}"
GLIBC_PREFIX="${GLIBC_PREFIX:-$PREFIX/glibc}"
RELEASE_URL="https://github.com/theonuverse/ovgl/releases/download/v0.2.0"

# ── colours ──────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info()  { printf "${GREEN}[INFO]${NC} %s\n" "$1"; }
warn()  { printf "${YELLOW}[WARN]${NC} %s\n" "$1"; }
error() { printf "${RED}[ERROR]${NC} %s\n" "$1" >&2; exit 1; }

# ── clean reinstall ─────────────────────────────────────────────────
clean_all() {
    info "Cleaning existing installations..."

    rm -f  "$PREFIX/bin/ovgl"                        2>/dev/null || true
    rm -f  "$GLIBC_PREFIX/lib/libovgl_preload.so"    2>/dev/null || true
    rm -f  "$GLIBC_PREFIX/bin/box64"                 2>/dev/null || true
    rm -rf "$GLIBC_PREFIX/lib_x86_64"                2>/dev/null || true
    rm -rf "$GLIBC_PREFIX/lib/x86_64-linux-gnu"      2>/dev/null || true

    # local build artefacts
    rm -f libovgl_preload.so preload_data.h ovgl     2>/dev/null || true

    info "Clean complete"
}

# ── libc.so symlink fix ─────────────────────────────────────────────
fix_libc_symlink() {
    local lib="$GLIBC_PREFIX/lib"

    if [ -f "$lib/libc.so" ] && [ ! -L "$lib/libc.so" ]; then
        info "Fixing libc.so → libc.so.6 symlink"
        mv "$lib/libc.so" "$lib/libc.so.script" || warn "Could not move libc.so"
    fi

    if [ ! -L "$lib/libc.so" ] && [ -f "$lib/libc.so.6" ]; then
        ln -sf libc.so.6 "$lib/libc.so" || warn "Could not create libc.so symlink"
    fi
}

# ── parse arguments ─────────────────────────────────────────────────
cd "$SCRIPT_DIR"

if [ "${1:-}" = "-c" ] || [ "${1:-}" = "--clean" ] || [ "${1:-}" = "--clean-reinstall" ]; then
    clean_all
fi

# ── prerequisites ────────────────────────────────────────────────────
if ! command -v clang >/dev/null 2>&1; then
    error "clang not found. Install with: pkg install clang"
fi

fix_libc_symlink

# ── step 0: x86_64 libraries ────────────────────────────────────────
LIB_X86_URL="${LIB_X86_64_URL:-$RELEASE_URL/lib_x86_64.tar.gz}"
TARGET_LIB_DIR="$GLIBC_PREFIX/lib/x86_64-linux-gnu"

info "Step 0: Ensuring x86_64 libs at $TARGET_LIB_DIR"

if [ ! -d "$TARGET_LIB_DIR" ] || [ -z "$(ls -A "$TARGET_LIB_DIR" 2>/dev/null)" ]; then
    info "Downloading x86_64 libs from $LIB_X86_URL"

    command -v curl >/dev/null 2>&1 || error "curl not found (pkg install curl)"
    curl -sL --fail -o lib_x86_64.tar.gz "$LIB_X86_URL" \
        || error "Failed to download $LIB_X86_URL"

    mkdir -p "$TARGET_LIB_DIR"
    tar -xzf lib_x86_64.tar.gz --strip-components=1 -C "$TARGET_LIB_DIR" \
        || error "Failed to extract lib_x86_64.tar.gz"
    rm -f lib_x86_64.tar.gz

    info "Installed x86_64 libs to $TARGET_LIB_DIR"
else
    info "x86_64 libs already present — skipping"
fi

# ── step 0b: box64 ──────────────────────────────────────────────────
BOX64_URL="${BOX64_URL:-$RELEASE_URL/box64}"
BOX64_DEST="$PREFIX/bin/box64"

if [ ! -x "$BOX64_DEST" ]; then
    info "Downloading box64 from $BOX64_URL"
    command -v curl >/dev/null 2>&1 || error "curl not found"
    curl -sL --fail -o box64.tmp "$BOX64_URL" \
        || error "Failed to download box64"
    install -m 755 box64.tmp "$BOX64_DEST"
    rm -f box64.tmp
    info "Installed box64 to $BOX64_DEST"
else
    info "box64 already present — skipping"
fi

mkdir -p "$GLIBC_PREFIX/bin"

# ── step 1: build preload library (glibc) ────────────────────────────
info "Step 1: Building preload library..."

if [ ! -d "$GLIBC_PREFIX" ]; then
    error "Glibc not found at $GLIBC_PREFIX. Install: pkg install glibc-repo && pkg install glibc"
fi

LD_PRELOAD="" clang \
    --sysroot="$GLIBC_PREFIX" \
    -shared -fPIC -O2 \
    -Wall -Wextra \
    --target=aarch64-linux-gnu \
    -I"$GLIBC_PREFIX/include" \
    -L"$GLIBC_PREFIX/lib" \
    -Wl,--dynamic-linker="$GLIBC_PREFIX/lib/ld-linux-aarch64.so.1" \
    -Wl,-rpath,"$GLIBC_PREFIX/lib" \
    -Wl,--no-as-needed \
    -o libovgl_preload.so \
    ovgl_preload.c \
    -lc -ldl

[ -f libovgl_preload.so ] || error "Failed to build libovgl_preload.so"
info "Built libovgl_preload.so ($(stat -c%s libovgl_preload.so) bytes)"

# ── step 2: generate embedded header ────────────────────────────────
info "Step 2: Generating preload_data.h..."

{
    echo "/* Auto-generated — do not edit */"
    echo "static const unsigned char preload_so_data[] = {"
    od -An -tx1 -v libovgl_preload.so \
        | sed 's/[0-9a-f]\{2\}/0x&,/g; s/  */ /g; s/^/    /'
    echo "};"
    echo "static const unsigned int preload_so_size = sizeof(preload_so_data);"
} > preload_data.h

info "Generated preload_data.h ($(wc -l < preload_data.h) lines)"

# ── step 3: build ovgl wrapper (bionic) ──────────────────────────────
info "Step 3: Building ovgl..."

clang \
    -O2 -Wall -Wextra -Wpedantic \
    -DEMBED_PRELOAD \
    -o ovgl \
    ovgl.c

[ -f ovgl ] || error "Failed to build ovgl"
info "Built ovgl ($(stat -c%s ovgl) bytes)"

# ── step 4: verify ──────────────────────────────────────────────────
info "Step 4: Verifying..."

printf "\n${BLUE}libovgl_preload.so:${NC}\n"
file libovgl_preload.so
readelf -d libovgl_preload.so 2>/dev/null \
    | grep -E "(NEEDED|RUNPATH|RPATH)" | head -5 || true

printf "\n${BLUE}ovgl:${NC}\n"
file ovgl
readelf -d ovgl 2>/dev/null \
    | grep -E "(NEEDED|INTERP)" | head -5 || true

# ── step 5: install ─────────────────────────────────────────────────
info "Step 5: Installing..."

install -m 755 ovgl "$PREFIX/bin/ovgl"
info "Installed ovgl → $PREFIX/bin/"

install -m 755 libovgl_preload.so "$GLIBC_PREFIX/lib/libovgl_preload.so"
info "Installed libovgl_preload.so → $GLIBC_PREFIX/lib/"

printf "\n${GREEN}════════════════════════════════════════${NC}\n"
printf "${GREEN}  ovgl v0.2.0 installed successfully${NC}\n"
printf "${GREEN}════════════════════════════════════════${NC}\n\n"
echo "Usage:  ovgl <binary> [args...]"
echo "        ovgl -h"
echo ""
