#!/bin/bash
# SPDX-License-Identifier: MIT
#
# ovgl quick installer (v0.2.0)
# Usage: curl -sL https://theonuverse.github.io/ovgl/setup | bash
#
set -eu

readonly VERSION="0.2.0"
readonly PREFIX="${PREFIX:-/data/data/com.termux/files/usr}"
readonly GLIBC_PREFIX="$PREFIX/glibc"
readonly RELEASE_BASE="https://github.com/theonuverse/ovgl/releases/download/v${VERSION}"

# -- colours -----------------------------------------------------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info()  { printf "${GREEN}[INFO]${NC} %s\n" "$1"; }
warn()  { printf "${YELLOW}[WARN]${NC} %s\n" "$1"; }
err()   { printf "${RED}[ERROR]${NC} %s\n" "$1"; }
die()   { err "$1"; exit 1; }

# -- helpers -----------------------------------------------------------------

print_header() {
	printf "\n"
	printf "${BLUE}+------------------------------------+${NC}\n"
	printf "${BLUE}|   ovgl Quick Installer  (v%s)   |${NC}\n" "$VERSION"
	printf "${BLUE}+------------------------------------+${NC}\n\n"
}

ensure_packages() {
	info "Updating packages ..."
	yes | pkg up >/dev/null 2>&1 || warn "pkg up returned non-zero"

	info "Installing required packages: glibc-repo glibc curl"
	pkg install glibc-repo -y >/dev/null 2>&1 || die "Failed to install glibc-repo"
	pkg install glibc curl   -y >/dev/null 2>&1 || die "Failed to install glibc or curl"
}

fix_libc_symlink() {
	local lib="$GLIBC_PREFIX/lib"

	if [ -f "$lib/libc.so" ] && [ ! -L "$lib/libc.so" ]; then
		info "Backing up linker script libc.so -> libc.so.script"
		mv "$lib/libc.so" "$lib/libc.so.script" || warn "Could not move libc.so"
	fi

	if [ ! -L "$lib/libc.so" ]; then
		ln -sf libc.so.6 "$lib/libc.so" || warn "Could not create libc.so symlink"
	fi
}

# download URL DEST [SHA256]
download() {
	local url="$RELEASE_BASE/$1"
	local dest="$2"
	local want="${3:-}"

	info "Downloading $1 ..."
	if ! curl -fsSL -o "$dest" "$url"; then
		warn "Failed to download $url"
		return 1
	fi

	if [ -n "$want" ] && command -v sha256sum >/dev/null 2>&1; then
		local got
		got=$(sha256sum "$dest" | awk '{print $1}')
		if [ "$got" != "$want" ]; then
			rm -f "$dest"
			die "Checksum mismatch for $dest (expected $want, got $got)"
		fi
		info "Checksum OK: $dest"
	fi
}

# -- main --------------------------------------------------------------------

main() {
	print_header
	ensure_packages
	fix_libc_symlink

	# Work in a temporary directory, cleaned up on exit.
	local tmpdir
	tmpdir=$(mktemp -d)
	trap 'rm -rf "$tmpdir"' EXIT
	cd "$tmpdir"

	# -- ovgl binary --
	download ovgl ovgl
	install -m 755 ovgl "$PREFIX/bin/ovgl"
	info "Installed ovgl to $PREFIX/bin/"

	# -- box64 --
	if download box64 box64; then
		install -m 755 box64 "$PREFIX/bin/box64"
		info "Installed box64 to $PREFIX/bin/"
	else
		warn "box64 not installed (download failed)"
	fi

	# -- x86_64 compatibility libraries --
	local libdir="$GLIBC_PREFIX/lib/x86_64-linux-gnu"
	mkdir -p "$libdir"

	if download lib_x86_64.tar.gz lib_x86_64.tar.gz; then
		tar -xzf lib_x86_64.tar.gz --strip-components=1 -C "$libdir"
		info "Installed x86_64 libs to $libdir"
	else
		warn "x86_64 libs not installed; populate $libdir manually"
	fi

	# -- preload library --
	if download libovgl_preload.so libovgl_preload.so; then
		install -m 755 libovgl_preload.so "$GLIBC_PREFIX/lib/libovgl_preload.so"
		info "Installed preload library to $GLIBC_PREFIX/lib/"
	else
		warn "Preload library not found; ovgl will extract its embedded copy"
	fi

	# -- glibc bin dir (for box64 wrapper) --
	mkdir -p "$GLIBC_PREFIX/bin"

	# -- done ----------------------------------------------------------------
	printf "\n"
	printf "${GREEN}+------------------------------------+${NC}\n"
	printf "${GREEN}|        Installation complete       |${NC}\n"
	printf "${GREEN}+------------------------------------+${NC}\n\n"
	printf "  ovgl / box64  : ${YELLOW}%s/bin/${NC}\n" "$PREFIX"
	printf "  x86_64 libs   : ${YELLOW}%s${NC}\n" "$libdir"
	printf "  preload       : ${YELLOW}%s/lib/libovgl_preload.so${NC}\n\n" "$GLIBC_PREFIX"
	printf "${BLUE}Run:${NC}  ovgl <binary> [args ...]\n\n"
}

main "$@"
