#!/data/data/com.termux/files/usr/bin/bash
# SPDX-License-Identifier: MIT
#
# bionilux — one-command installer
#
set -eu

readonly VERSION="0.2.0"
readonly PREFIX="${PREFIX:-/data/data/com.termux/files/usr}"
readonly GLIBC_PREFIX="$PREFIX/glibc"
readonly BASE="https://github.com/theonuverse/bionilux/releases/download/v${VERSION}"

# ── colours ──────────────────────────────────────────────────────────
G='\033[0;32m' Y='\033[1;33m' R='\033[0;31m' B='\033[0;34m' N='\033[0m'

ok()    { printf "${G}[✓]${N} %s\n" "$*"; }
info()  { printf "${B}[·]${N} %s\n" "$*"; }
warn()  { printf "${Y}[!]${N} %s\n" "$*"; }
die()   { printf "${R}[✗]${N} %s\n" "$*" >&2; exit 1; }

# ── pre-flight ───────────────────────────────────────────────────────
info "Checking prerequisites..."
pkg update -y > /dev/null 2>&1 || warn "pkg update failed, attempting to continue..."
pkg install -y binutils glibc-repo clang curl file git > /dev/null 2>&1 \
    || die "Failed to install prerequisites"
pkg install -y glibc > /dev/null 2>&1 || die "Failed to install glibc"
ok "Prerequisites installed."

# ── libc.so symlink fix ─────────────────────────────────────────────
fix_libc() {
    local lib="$GLIBC_PREFIX/lib"
    if [ -f "$lib/libc.so" ] && [ ! -L "$lib/libc.so" ]; then
        mv "$lib/libc.so" "$lib/libc.so.script" 2>/dev/null || true
    fi
    [ -L "$lib/libc.so" ] || ln -sf libc.so.6 "$lib/libc.so" 2>/dev/null || true
}

# ── download helper ──────────────────────────────────────────────────
dl() {
    local name="$1" dest="$2"
    info "Downloading $name ..."
    curl -fSL --progress-bar -o "$dest" "$BASE/$name" || die "Download failed: $name"
}

# ── checksum verification ────────────────────────────────────────────
verify() {
    local file="$1"
    if [ -f SHA256SUMS ] && command -v sha256sum >/dev/null 2>&1; then
        if sha256sum -c SHA256SUMS --ignore-missing --status 2>/dev/null; then
            ok "checksum OK: $file"
        else
            warn "checksum mismatch or not listed: $file (continuing)"
        fi
    fi
}

# ── main ─────────────────────────────────────────────────────────────
printf "\n${B}  bionilux installer v${VERSION}${N}\n\n"

fix_libc

tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT
cd "$tmpdir"

# Try to fetch checksums
curl -fsSL -o SHA256SUMS "$BASE/SHA256SUMS" 2>/dev/null || true

# 1) bionilux binary
dl bionilux bionilux
verify bionilux
install -m 755 bionilux "$PREFIX/bin/bionilux"
ok "bionilux → $PREFIX/bin/"

# 2) libbionilux_preload.so
dl libbionilux_preload.so libbionilux_preload.so
verify libbionilux_preload.so
install -m 755 libbionilux_preload.so "$GLIBC_PREFIX/lib/libbionilux_preload.so"
ok "preload  → $GLIBC_PREFIX/lib/"

# 3) box64
info "Fetching latest box64 .deb name..."
DEB_NAME=$(curl -fsSL https://api.github.com/repos/Pi-Apps-Coders/box64-debs/contents/debian \
    | grep -oP 'box64-android_[^ "]+?_arm64\.deb' \
    | sort -V | tail -n 1) \
    || die "Failed to query box64 releases"
[ -n "$DEB_NAME" ] || die "No box64 .deb found"

info "Downloading $DEB_NAME ..."
curl -fSL --progress-bar -o box64.deb \
    "https://github.com/Pi-Apps-Coders/box64-debs/raw/master/debian/$DEB_NAME" \
    || die "Download failed: $DEB_NAME"

dpkg-deb -x box64.deb box64_out || die "Failed to extract box64 .deb"
install -m 755 box64_out/usr/local/bin/box64 "$PREFIX/bin/box64" \
    || die "Failed to install box64"
rm -rf box64.deb box64_out
ok "box64     → $PREFIX/bin/"

# 4) x86_64 compat libs
info "Fetching latest x86_64 library archive name..."
ARCHIVE_NAME=$(curl -fsSL https://easycli.sh/proot-distro/ \
    | grep -oP 'debian-trixie-x86_64-pd-v\d+\.\d+\.\d+\.tar\.xz' \
    | sort -V | tail -n 1) \
    || die "Failed to find x86_64 archive"
[ -n "$ARCHIVE_NAME" ] || die "No x86_64 archive found"

info "Downloading $ARCHIVE_NAME ..."
curl -fSL --progress-bar -o "$ARCHIVE_NAME" \
    "https://easycli.sh/proot-distro/$ARCHIVE_NAME" \
    || die "Download failed: $ARCHIVE_NAME"

mkdir -p "$GLIBC_PREFIX/lib/x86_64-linux-gnu"
tar --exclude='engines-3' \
    --exclude='gconv' \
    --exclude='ossl-modules' \
    --exclude='perl-base' \
    --exclude='security' \
    -xf "$ARCHIVE_NAME" \
    --strip-components=4 \
    -C "$GLIBC_PREFIX/lib/x86_64-linux-gnu" \
    debian-trixie-x86_64/usr/lib/x86_64-linux-gnu \
    || die "Extraction failed"
rm -f "$ARCHIVE_NAME"
ok "x86_64   → $GLIBC_PREFIX/lib/x86_64-linux-gnu/"

# 5) box64 wrapper (glibc bin dir)
mkdir -p "$GLIBC_PREFIX/bin"

# ── done ─────────────────────────────────────────────────────────────
printf "\n${G}  ✓ bionilux v${VERSION} installed${N}\n\n"
printf "  ${Y}bionilux <binary> [args...]${N}      Run a binary\n"
printf "  ${Y}bionilux -d <binary>${N}            Debug mode\n"
printf "  ${Y}bionilux --version${N}               Version info\n\n"
